/* pages/levels/levels.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  padding: 60rpx 40rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
}

.difficulty-tag {
  background: #f5a623;
  color: #1a1a2e;
  font-size: 24rpx;
  font-weight: bold;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

.levels-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  justify-content: center;
}

.level-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.unlocked {
  background: linear-gradient(135deg, #0f3460, #533483);
  border: 2rpx solid #f5a623;
}

.locked {
  background: #2a2a4a;
  border: 2rpx solid #444466;
  opacity: 0.5;
}

.level-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

.level-status {
  font-size: 30rpx;
}

.back-btn {
  margin-top: 80rpx;
  text-align: center;
  color: #aaaacc;
  font-size: 30rpx;
}
