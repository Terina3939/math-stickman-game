<!-- pages/levels/levels.wxml -->
<view class="container">
  <view class="header">
    <text class="title">选择关卡</text>
    <text class="difficulty-tag">{{difficultyName}}</text>
  </view>

  <view class="levels-grid">
    <view
      wx:for="{{levels}}"
      wx:key="index"
      class="level-item {{item.unlocked ? 'unlocked' : 'locked'}}"
      bindtap="{{item.unlocked ? 'startLevel' : ''}}"
      data-level="{{item.num}}"
    >
      <text class="level-num">{{item.num}}</text>
      <text class="level-status">{{item.unlocked ? '⚔️' : '🔒'}}</text>
    </view>
  </view>

  <view class="back-btn" bindtap="goBack">
    <text>← 返回</text>
  </view>
</view>
