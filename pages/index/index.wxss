/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.title-area {
  text-align: center;
  margin-bottom: 60rpx;
}

.game-title {
  display: block;
  font-size: 60rpx;
  font-weight: bold;
  color: #f5a623;
  text-shadow: 0 0 20rpx rgba(245,166,35,0.5);
}

.game-subtitle {
  display: block;
  font-size: 28rpx;
  color: #aaaacc;
  margin-top: 10rpx;
}

.stickman-area {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 80rpx;
  gap: 40rpx;
}

.stickman {
  font-size: 100rpx;
}

.vs {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.monster {
  font-size: 100rpx;
}

.choose-text {
  display: block;
  text-align: center;
  font-size: 32rpx;
  color: #aaaacc;
  margin-bottom: 30rpx;
}

.diff-btn {
  width: 620rpx;
  display: flex;
  align-items: center;
  padding: 30rpx 40rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  gap: 30rpx;
}

.easy {
  background: linear-gradient(135deg, #11998e, #38ef7d);
}

.medium {
  background: linear-gradient(135deg, #f7971e, #ffd200);
}

.hard {
  background: linear-gradient(135deg, #eb3349, #f45c43);
}

.diff-icon {
  font-size: 36rpx;
}

.diff-info {
  display: flex;
  flex-direction: column;
}

.diff-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.diff-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
}

.leaderboard-btn {
  margin-top: 40rpx;
  padding: 20rpx 60rpx;
  background: rgba(255,255,255,0.08);
  border: 2rpx solid #f5a623;
  border-radius: 40rpx;
  color: #f5a623;
  font-size: 28rpx;
}
