/* pages/result/result.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 60rpx;
}

.result-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.result-emoji {
  font-size: 160rpx;
  animation: bounce 0.6s ease;
}

@keyframes bounce {
  0% { transform: scale(0); }
  60% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

.result-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #f5a623;
}

.result-sub {
  font-size: 30rpx;
  color: #aaaacc;
}

.btn-area {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 500rpx;
}

.btn-retry {
  background: linear-gradient(135deg, #11998e, #38ef7d);
  padding: 30rpx;
  border-radius: 20rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #003300;
}

.btn-home {
  background: linear-gradient(135deg, #0f3460, #533483);
  padding: 30rpx;
  border-radius: 20rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #ffffff;
  border: 2rpx solid #8866ff;
}
