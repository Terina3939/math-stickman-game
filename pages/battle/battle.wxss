.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0d0d1a 0%, #1a1a2e 60%, #16213e 100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
}

/* 状态栏 */
.status-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: rgba(0,0,0,0.5);
  border-bottom: 2rpx solid #333366;
}
.hp-area { display: flex; gap: 4rpx; }
.heart { font-size: 30rpx; transition: opacity 0.3s; }
.heart.dead { filter: grayscale(100%); opacity: 0.3; }
.stage-info { display: flex; flex-direction: column; align-items: center; }
.stage-name { font-size: 20rpx; color: #f5a623; font-weight: bold; }
.level-text { font-size: 26rpx; color: #ffffff; font-weight: bold; }
.monster-hp-area { display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; }
.monster-hp-bar { width: 150rpx; height: 14rpx; background: #333355; border-radius: 7rpx; overflow: hidden; }
.monster-hp-fill { height: 100%; background: linear-gradient(90deg, #ff4444, #ff8800); border-radius: 7rpx; transition: width 0.4s ease; }
.monster-hp-text { font-size: 18rpx; color: #ff8888; }

/* 战斗场景 */
.battle-scene {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  height: 280rpx;
}
.player-side, .monster-side {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  position: relative;
}
.question-bubble {
  position: absolute;
  top: -80rpx;
  background: #ffffff;
  color: #1a1a2e;
  padding: 10rpx 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: bold;
  white-space: nowrap;
  opacity: 0;
  transform: translateY(10rpx);
  transition: opacity 0.3s, transform 0.3s;
  z-index: 10;
}
.question-bubble.visible { opacity: 1; transform: translateY(0); }
.question-bubble::after {
  content: '';
  position: absolute;
  bottom: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  border: 8rpx solid transparent;
  border-top-color: #ffffff;
}
.stickman { font-size: 100rpx; display: block; }
.monster  { font-size: 100rpx; display: block; }
.role-label { font-size: 20rpx; color: #888899; }

.attack-anim { animation: playerAttack 0.5s ease; }
@keyframes playerAttack {
  0%   { transform: translateX(0); }
  50%  { transform: translateX(40rpx); }
  100% { transform: translateX(0); }
}
.middle-area { display: flex; align-items: center; justify-content: center; width: 100rpx; }
.wave { font-size: 60rpx; opacity: 0; }
.wave-anim { animation: waveMove 0.5s ease forwards; }
@keyframes waveMove {
  0%   { opacity: 1; transform: translateX(-60rpx) scale(0.5); }
  50%  { opacity: 1; transform: translateX(0) scale(1.2); }
  100% { opacity: 0; transform: translateX(40rpx) scale(0.8); }
}
.hit-anim { animation: monsterHit 0.4s ease; }
@keyframes monsterHit {
  0%,100% { transform: translateX(0); }
  25%     { transform: translateX(20rpx) rotate(10deg); }
  75%     { transform: translateX(-10rpx) rotate(-5deg); }
}
.monster-attack-anim { animation: monsterAttack 0.6s ease; }
@keyframes monsterAttack {
  0%   { transform: translateX(0); }
  40%  { transform: translateX(-50rpx) scale(1.2); }
  100% { transform: translateX(0) scale(1); }
}

/* 倒计时条：5档固定class，不用内联style */
.timer-bar-wrap {
  height: 10rpx;
  background: #222244;
  margin: 0 30rpx;
  border-radius: 5rpx;
  overflow: hidden;
}
.timer-bar {
  height: 100%;
  width: 100%;
  background: linear-gradient(90deg, #38ef7d, #f5a623, #ff4444);
  border-radius: 5rpx;
  transform-origin: left;
  animation: timerShrink linear forwards;
}
.timer-s1  { animation-duration: 4000ms; }
.timer-s2  { animation-duration: 3000ms; }
.timer-s3  { animation-duration: 2200ms; }
.timer-s4  { animation-duration: 1600ms; }
.timer-s5  { animation-duration: 1200ms; }
@keyframes timerShrink {
  from { transform: scaleX(1); }
  to   { transform: scaleX(0); }
}

/* 掉落选项区域 */
.falling-area {
  position: relative;
  height: 320rpx;
  margin: 10rpx 0;
}

/* 选项本体：不在这里写animation，由fall-class控制 */
.option-item {
  position: absolute;
  top: 0;
  background: linear-gradient(135deg, #0f3460, #533483);
  border: 2rpx solid #8866ff;
  border-radius: 16rpx;
  width: 150rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 关键：用transform而非top做动画，性能更好不闪烁 */
  animation-fill-mode: forwards;
  animation-timing-function: linear;
}

/* 5档掉落速度，对应5个阶段 */
.fall-s1 { animation: fallDown 4000ms linear forwards; }
.fall-s2 { animation: fallDown 3000ms linear forwards; }
.fall-s3 { animation: fallDown 2200ms linear forwards; }
.fall-s4 { animation: fallDown 1600ms linear forwards; }
.fall-s5 { animation: fallDown 1200ms linear forwards; }

@keyframes fallDown {
  0%   { transform: translateY(-80rpx); opacity: 0; }
  10%  { opacity: 1; }
  100% { transform: translateY(300rpx); opacity: 1; }
}

.option-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 反馈 */
.feedback {
  position: fixed;
  bottom: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 16rpx 50rpx;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  animation: fadeIn 0.3s ease;
  z-index: 100;
}
.correct { background: rgba(56,239,125,0.92); color: #003300; }
.wrong   { background: rgba(255,80,80,0.92);  color: #ffffff; }
@keyframes fadeIn {
  from { opacity: 0; transform: translateX(-50%) translateY(20rpx); }
  to   { opacity: 1; transform: translateX(-50%) translateY(0); }
}

/* 通关区域 */
.next-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 40rpx;
}
.next-title { font-size: 52rpx; font-weight: bold; color: #f5a623; }
.next-sub   { font-size: 28rpx; color: #aaaacc; }
.next-btn {
  width: 500rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #11998e, #38ef7d);
  border-radius: 20rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #003300;
}
.settle-btn {
  width: 500rpx;
  padding: 30rpx;
  background: rgba(255,255,255,0.05);
  border: 2rpx solid #f5a623;
  border-radius: 20rpx;
  text-align: center;
  font-size: 30rpx;
  color: #f5a623;
}
