<view class="container">

  <!-- 顶部状态栏 -->
  <view class="status-bar">
    <view class="hp-area">
      <text wx:for="{{heartList}}" wx:key="index" class="heart {{item ? '' : 'dead'}}">❤️</text>
    </view>
    <view class="stage-info">
      <text class="stage-name">{{stageName}}</text>
      <text class="level-text">第 {{level}} 关</text>
    </view>
    <view class="monster-hp-area">
      <view class="monster-hp-bar">
        <view class="monster-hp-fill" style="width:{{monsterHpPercent}}%"></view>
      </view>
      <text class="monster-hp-text">{{monsterHp}}/{{monsterMaxHp}}</text>
    </view>
  </view>

  <!-- 战斗场景 -->
  <view class="battle-scene">
    <view class="player-side">
      <view class="question-bubble {{questionVisible ? 'visible' : ''}}">
        <text class="question-text">{{currentQuestion}}</text>
      </view>
      <text class="stickman {{playerAttacking ? 'attack-anim' : ''}}">🧍</text>
      <text class="role-label">勇士</text>
    </view>
    <view class="middle-area">
      <text class="wave {{showWave ? 'wave-anim' : ''}}">💥</text>
    </view>
    <view class="monster-side">
      <text class="monster {{monsterHit ? 'hit-anim' : ''}} {{monsterAttacking ? 'monster-attack-anim' : ''}}">{{monsterEmoji}}</text>
      <text class="role-label">怪物</text>
    </view>
  </view>

  <!-- 倒计时条 -->
  <view class="timer-bar-wrap" wx:if="{{timerRunning}}">
    <view class="timer-bar timer-{{timerClass}}"></view>
  </view>

  <!-- 掉落选项：用 falling-s/m/l/xl/xxl 五档固定class控制速度 -->
  <view class="falling-area" wx:if="{{!showNextBtn}}">
    <view
      wx:for="{{options}}"
      wx:key="index"
      class="option-item fall-{{fallClass}}"
      style="left:{{item.left}}%"
      bindtap="selectOption"
      data-value="{{item.value}}"
    >
      <text class="option-text">{{item.value}}</text>
    </view>
  </view>

  <!-- 反馈提示 -->
  <view class="feedback {{feedbackType}}" wx:if="{{feedbackMsg}}">
    <text>{{feedbackMsg}}</text>
  </view>

  <!-- 通关按钮 -->
  <view class="next-area" wx:if="{{showNextBtn}}">
    <text class="next-title">🎉 怪物消灭！</text>
    <text class="next-sub">第 {{level}} 关通过</text>
    <view class="next-btn" bindtap="goNextLevel">
      <text>⚔️ 进入下一关</text>
    </view>
    <view class="settle-btn" bindtap="goSettle">
      <text>🏆 结算上榜</text>
    </view>
  </view>

</view>
