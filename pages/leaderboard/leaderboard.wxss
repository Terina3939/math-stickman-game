.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  padding: 40rpx;
}

.header { text-align: center; margin-bottom: 40rpx; }
.title  { font-size: 52rpx; font-weight: bold; color: #f5a623; }

.tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.tab {
  flex: 1;
  padding: 18rpx 0;
  text-align: center;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid #333366;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #aaaacc;
}

.tab.active {
  background: rgba(245,166,35,0.15);
  border-color: #f5a623;
  color: #f5a623;
  font-weight: bold;
}

.list { display: flex; flex-direction: column; gap: 16rpx; }

.list-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: rgba(255,255,255,0.05);
  border: 2rpx solid #333355;
  border-radius: 16rpx;
  padding: 24rpx;
}

.list-item.top {
  background: rgba(245,166,35,0.08);
  border-color: #f5a623;
}

.rank { font-size: 36rpx; width: 60rpx; text-align: center; }

.info { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.name { font-size: 30rpx; font-weight: bold; color: #ffffff; }
.detail { font-size: 20rpx; color: #888899; }

.score { font-size: 28rpx; font-weight: bold; color: #f5a623; }

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  margin-top: 120rpx;
}

.empty-icon { font-size: 100rpx; }
.empty-text { font-size: 28rpx; color: #666688; }

.back-btn {
  margin-top: 60rpx;
  text-align: center;
  color: #aaaacc;
  font-size: 30rpx;
}
